---
interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonical?: string;
  jsonLd?: object;
  noindex?: boolean;
}

const {
  title,
  description = 'Terrenos, lotes y lotificaciones en Honduras. Le acompañamos desde la primera visita hasta la firma de escritura.',
  ogTitle,
  ogDescription,
  ogImage,
  canonical,
  jsonLd,
  noindex = false,
} = Astro.props;

const resolvedOgTitle = ogTitle || title;
const resolvedOgDescription = ogDescription || description;
const resolvedOgImage = ogImage || 'https://www.aabienes.com/banner-web.jpg';
// Canonical automático desde site + ruta (a menos que la página pase uno explícito)
const resolvedCanonical = canonical
  || (Astro.site ? new URL(Astro.url.pathname.replace(/\/$/, '') || '/', Astro.site).href : undefined);

// JSON-LD global: agencia inmobiliaria
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: 'A&A Inmobiliaria',
  url: 'https://www.aabienes.com',
  logo: 'https://www.aabienes.com/logo-mark.webp',
  image: 'https://www.aabienes.com/banner-web.jpg',
  telephone: '+50499383699',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'El Progreso',
    addressRegion: 'Yoro',
    addressCountry: 'HN',
  },
  areaServed: 'Honduras',
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('aa_pub_theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <link rel="icon" type="image/webp" href="/logo-mark.webp" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && resolvedCanonical && <link rel="canonical" href={resolvedCanonical} />}
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Preconnect to Cloudinary and OpenStreetMap -->
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
    <link rel="dns-prefetch" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://www.openstreetmap.org" />
    <link rel="dns-prefetch" href="https://www.openstreetmap.org" />

    <!-- Preload critical fonts (WOFF2 — 68% smaller than TTF) -->
    <link rel="preload" href="/fonts/PlusJakartaSans-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/PlusJakartaSans-SemiBold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/PlusJakartaSans-Bold.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_HN" />
    <meta property="og:site_name" content="A&A Inmobiliaria" />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    {resolvedCanonical && <meta property="og:url" content={resolvedCanonical} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <slot />
  </body>
</html>

<!-- Critical CSS inlined to avoid render-blocking on first paint -->
<style is:inline>
  @font-face{font-family:'Plus Jakarta Sans';src:url('/fonts/PlusJakartaSans-Regular.woff2') format('woff2');font-weight:400;font-style:normal;font-display:swap}
  @font-face{font-family:'Plus Jakarta Sans';src:url('/fonts/PlusJakartaSans-SemiBold.woff2') format('woff2');font-weight:600;font-style:normal;font-display:swap}
  @font-face{font-family:'Plus Jakarta Sans';src:url('/fonts/PlusJakartaSans-Bold.woff2') format('woff2');font-weight:700;font-style:normal;font-display:swap}
  html{-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
  body{font-family:'Plus Jakarta Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#111113;background:#FAF8F3;margin:0}
</style>

<!-- Full CSS loaded normally (still render-blocking but browser already has critical styles above) -->
<style is:global>
  @import '../styles/global.css';
</style>
