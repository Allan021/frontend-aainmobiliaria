import { FavoritesApp } from '../ui/components/account/FavoritesApp';
import { WhatsAppModal } from '../ui/components/property/WhatsAppModal';
---

<BaseLayout title="Mis favoritos — A&A Inmobiliaria" description="Sus propiedades guardadas." noindex>
