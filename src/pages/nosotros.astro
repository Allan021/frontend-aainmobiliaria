---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Header } from '../ui/components/layout/Header';
import { Footer } from '../ui/components/layout/Footer';
import { AboutPage, WhatsAppFAB } from '../ui/components/property/WebsiteApp';
import { WhatsAppModal } from '../ui/components/property/WhatsAppModal';
---

<BaseLayout
  title="Nosotros — A&A Inmobiliaria"
  description="A&A Inmobiliaria nace en El Progreso, Yoro con una premisa: cada propiedad verificada, escriturada y lista para cambiar de manos sin sorpresas."
  canonical="https://www.aabienes.com/nosotros"
>
  <Header client:load currentRoute="about" />
  <AboutPage client:load />
  <Footer />
  <WhatsAppFAB client:visible />
  <WhatsAppModal client:idle open={false} onClose={() => {}} />
</BaseLayout>
