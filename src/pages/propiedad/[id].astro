---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Header } from '../../ui/components/layout/Header';
import { Footer } from '../../ui/components/layout/Footer';
import { PropertyDetail } from '../../ui/components/property/PropertyDetail';
import { WhatsAppModal } from '../../ui/components/property/WhatsAppModal';
import { WhatsAppFAB } from '../../ui/components/property/WebsiteApp';
import { serverFetch } from '../../infrastructure/api/client';
import type { Property, PaginatedResponse } from '../../core/domain/entities/types';

export async function getStaticPaths() {
  try {
    const data = await serverFetch<PaginatedResponse<Property>>(
      '/properties?limit=300'
    );
    const properties: Property[] = data.data ?? [];
    return properties.map((p) => ({
      params: { id: p.id },
      props: { property: p },
    }));
  } catch {
    return [];
  }
}

const { property } = Astro.props as { property: Property };

const rawDesc = `${property.type} en ${property.municipio}, ${property.departamento}. ${property.description}`;
const pageDescription = rawDesc.slice(0, 155).trimEnd() + (rawDesc.length > 155 ? '...' : '');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateListing',
  name: property.title,
  description: property.description,
  url: `https://www.aabienes.com/propiedad/${property.id}`,
  image: property.images?.[0]?.url || '',
  address: {
    '@type': 'PostalAddress',
    addressLocality: property.municipio,
    addressRegion: property.departamento,
    addressCountry: 'HN',
  },
  offers: {
    '@type': 'Offer',
    price: property.price,
    priceCurrency: property.currency === 'L' ? 'HNL' : 'USD',
    availability: 'https://schema.org/InStock',
  },
};
---

<BaseLayout
  title={`${property.title} — A&A Inmobiliaria`}
  description={pageDescription}
  ogTitle={`${property.title} — A&A Inmobiliaria`}
  ogDescription={pageDescription}
  ogImage={property.images?.[0]?.url}
  canonical={`https://www.aabienes.com/propiedad/${property.id}`}
  jsonLd={jsonLd}
>
  <Header client:load currentRoute="catalog" />
  <PropertyDetail
    client:load
    property={property}
    standalone
  />
  <Footer />
  <WhatsAppFAB client:visible />
  <WhatsAppModal client:visible open={false} onClose={() => {}} />
</BaseLayout>
