---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Header } from '../../ui/components/layout/Header';
import { Footer } from '../../ui/components/layout/Footer';
import { PropertyFicha } from '../../ui/components/property/PropertyFicha';
import { WhatsAppModal } from '../../ui/components/property/WhatsAppModal';
import { serverFetch } from '../../infrastructure/api/client';
import { cleanTitle, stripEmojis } from '../../core/domain/entities/types';
import type { Property, PaginatedResponse } from '../../core/domain/entities/types';

export async function getStaticPaths() {
  try {
    const data = await serverFetch<PaginatedResponse<Property>>(
      '/properties?limit=300'
    );
    const properties: Property[] = data.data ?? [];
    return properties.map((p) => ({
      params: { id: p.id },
      props: { property: p },
    }));
  } catch {
    return [];
  }
}

const { property } = Astro.props as { property: Property };

// Meta limpios: sin emojis del título/descripción que el admin escribió en la DB
const pageTitle = stripEmojis(cleanTitle(property.title));
const rawDesc = stripEmojis(`${property.type} en ${property.municipio}, ${property.departamento}. ${property.description}`);
const pageDescription = rawDesc.slice(0, 155).trimEnd() + (rawDesc.length > 155 ? '...' : '');

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'RealEstateListing',
    name: pageTitle,
    description: stripEmojis(property.description),
    url: `https://www.aabienes.com/propiedad/${property.id}`,
    image: property.images?.[0]?.url || '',
    address: {
      '@type': 'PostalAddress',
      addressLocality: property.municipio,
      addressRegion: property.departamento,
      addressCountry: 'HN',
    },
    offers: {
      '@type': 'Offer',
      price: property.price,
      priceCurrency: property.currency === 'L' ? 'HNL' : 'USD',
      availability: 'https://schema.org/InStock',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://www.aabienes.com/' },
      { '@type': 'ListItem', position: 2, name: 'Propiedades', item: 'https://www.aabienes.com/buscar' },
      { '@type': 'ListItem', position: 3, name: pageTitle, item: `https://www.aabienes.com/propiedad/${property.id}` },
    ],
  },
];
---

<BaseLayout
  title={`${pageTitle} — A&A Inmobiliaria`}
  description={pageDescription}
  ogTitle={`${pageTitle} — A&A Inmobiliaria`}
  ogDescription={pageDescription}
  ogImage={property.images?.[0]?.url}
  ogType="product"
  canonical={`https://www.aabienes.com/propiedad/${property.id}`}
  jsonLd={jsonLd}
>
  <Header client:load currentRoute="catalog" />
  <PropertyFicha client:load property={property} standalone />
  <Footer />
  <WhatsAppModal client:visible open={false} onClose={() => {}} />
</BaseLayout>
