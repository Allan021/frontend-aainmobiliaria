---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Header } from '../ui/components/layout/Header';
import { Footer } from '../ui/components/layout/Footer';
import { HomeLanding } from '../ui/components/home/HomeLanding';
import { WhatsAppFAB } from '../ui/components/property/WebsiteApp';
import { WhatsAppModal } from '../ui/components/property/WhatsAppModal';

// Sitelinks searchbox: Google puede mostrar buscador directo al sitio
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'A&A Inmobiliaria',
  url: 'https://www.aabienes.com',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: 'https://www.aabienes.com/buscar?q={search_term_string}' },
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="A&A Inmobiliaria — Casas, Terrenos y Lotes en Honduras"
  description="Compre o venda su propiedad en Honduras. Casas, terrenos y lotes verificados con escrituración al día. Búsqueda con mapa, visitas agendadas y financiamiento."
  jsonLd={websiteJsonLd}
>
  <Header client:load currentRoute="home" />
  <HomeLanding client:load />
  <Footer />
  <WhatsAppFAB client:visible />
  <WhatsAppModal client:idle open={false} onClose={() => {}} />
</BaseLayout>
