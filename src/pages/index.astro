---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Header } from '../ui/components/layout/Header';
import { Footer } from '../ui/components/layout/Footer';
import { Hero } from '../ui/components/property/Hero';
import { FeaturedSection, TrustBand, CTASection, WhatsAppFAB } from '../ui/components/property/WebsiteApp';
import { ReviewsSection } from '../ui/components/property/ReviewsSection';
import { WhatsAppModal } from '../ui/components/property/WhatsAppModal';
---

<BaseLayout title="A&A Inmobiliaria — Tu Propiedad. Nuestra Misión.">
  <Header client:load currentRoute="home" />
  <Hero client:load />
  <FeaturedSection client:visible />
  <TrustBand />
  <ReviewsSection client:visible />
  <CTASection client:visible />
  <Footer />
  <WhatsAppFAB client:visible />
  <WhatsAppModal client:load open={false} onClose={() => {}} />
</BaseLayout>
