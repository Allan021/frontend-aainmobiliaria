---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Header } from '../ui/components/layout/Header';
import { Footer } from '../ui/components/layout/Footer';
import { CatalogView, WhatsAppFAB } from '../ui/components/property/WebsiteApp';
import { WhatsAppModal } from '../ui/components/property/WhatsAppModal';

const initialFilters = { type: 'lotificadora' };
---

<BaseLayout
  title="Lotificaciones en Honduras — A&A Inmobiliaria"
  description="Proyectos de lotificación verificados en Honduras. Lotes individuales disponibles con financiamiento. A&A Inmobiliaria, El Progreso, Yoro."
  canonical="https://www.aabienes.com/lotificaciones"
>
  <Header client:load currentRoute="catalog" />
  <CatalogView client:load initialFilters={initialFilters} />
  <Footer />
  <WhatsAppFAB client:visible />
  <WhatsAppModal client:load open={false} onClose={() => {}} />
</BaseLayout>
